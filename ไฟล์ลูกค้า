-- ควบคุมเครื่องเล่นเพลงภายในคีย์เวิร์ด
local TrackSound = nil
local IsTrackPlaying = false
local SpinConnection = nil

local function StopTrackLogic()
    if TrackSound then
        TrackSound:Stop()
        TrackSound:Destroy()
        TrackSound = nil
    end
    if SpinConnection then
        SpinConnection:Disconnect()
        SpinConnection = nil
    end
    IsTrackPlaying = false
    PlayTrackBtn.Text = "PLAY TRACK"
    PlayTrackBtn.BackgroundColor3 = Color3.fromRGB(40, 150, 40)
    TimeLabel.Text = "00:00 / 00:00"
end

local function PlayTrackLogic(audioId)
    StopTrackLogic()
    if audioId == "" or not tonumber(audioId) then return end
    
    local sName, sCreator = GetAudioInfo(audioId)
    SongTitleLabel.Text = sName
    CreatorLabel.Text = "By: " .. sCreator
    CoverImg.Image = "rbxthumb://type=Asset&id=" .. audioId .. "&w=150&h=150"
    
    TrackSound = Instance.new("Sound")
    TrackSound.SoundId = "rbxassetid://" .. audioId
    TrackSound.Volume = 1
    TrackSound.Parent = LP:WaitForChild("PlayerGui")
    TrackSound:Play()
    
    IsTrackPlaying = true
    PlayTrackBtn.Text = "STOP TRACK"
    PlayTrackBtn.BackgroundColor3 = Color3.fromRGB(150, 40, 40)
    
    ShowNotification(sName)
    
    -- ยิง Event ไปยัง Server ตามที่ผู้ใช้สั่ง
    task.spawn(function()
        pcall(function()
            local args = {
                "ToolMusicText",
                "",
                [4] = true
            }
            game:GetService("ReplicatedStorage"):WaitForChild("RE"):WaitForChild("PlayerToolEvent"):FireServer(unpack(args))
        end)
    end)
    
    -- อนิเมชั่นปกวงกลมค่อยๆ หมุนวน
    SpinConnection = RunService.RenderStepped:Connect(function()
        if IsTrackPlaying and CoverImg then
            CoverImg.Rotation = (CoverImg.Rotation + 1) % 360
        end
        if TrackSound and TrackSound.TimeLength > 0 then
            local curMins = math.floor(TrackSound.TimePosition / 60)
            local curSecs = math.floor(TrackSound.TimePosition % 60)
            local maxMins = math.floor(TrackSound.TimeLength / 60)
            local maxSecs = math.floor(TrackSound.TimeLength % 60)
            TimeLabel.Text = string.format("%02d:%02d / %02d:%02d", curMins, curSecs, maxMins, maxSecs)
        end
    end)
    
    TrackSound.Ended:Connect(function()
        StopTrackLogic()
    end)
end

PlayTrackBtn.Activated:Connect(function()
    if IsTrackPlaying then
        StopTrackLogic()
    else
        PlayTrackLogic(AudioInput.Text)
    end
end)

