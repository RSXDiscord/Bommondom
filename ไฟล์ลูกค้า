local function GetActualPlayerDetails(targetPlayer)
    local codeOutput = "-- [[ SCANNER REPORT ]]\n"
    codeOutput = codeOutput .. "Target_User: \"" .. targetPlayer.Name .. "\"\n"
    codeOutput = codeOutput .. "Target_ID: " .. targetPlayer.UserId .. "\n"
    codeOutput = codeOutput .. "Account_Age: " .. targetPlayer.AccountAge .. " Days\n\n"
    
    codeOutput = codeOutput .. "-- [[ DETECTED SOUND OBJECTS & CODES ]]\n"
    local foundSound = false
    
    if targetPlayer.Character then
        for _, s in pairs(targetPlayer.Character:GetDescendants()) do
            if s:IsA("Sound") then
                foundSound = true
                local cleanId = s.SoundId:match("%d+") or "No ID"
                codeOutput = codeOutput .. "Instance: " .. s:GetFullName() .. "\n"
                codeOutput = codeOutput .. "└─ SoundId = \"rbxassetid://" .. cleanId .. "\"\n"
                codeOutput = codeOutput .. "└─ Volume = " .. tostring(s.Volume) .. "\n"
                codeOutput = codeOutput .. "└─ Playing = " .. tostring(s.IsPlaying) .. "\n\n"
            end
        end
    end
    
    codeOutput = codeOutput .. "-- [[ BACKPACK INVENTORY CODES ]]\n"
    for _, item in pairs(targetPlayer.Backpack:GetChildren()) do
        if item:IsA("Tool") then
            codeOutput = codeOutput .. "Found_Tool: Name = \"" .. item.Name .. "\" | Class = \"" .. item.ClassName .. "\"\n"
            for _, sub in pairs(item:GetDescendants()) do
                if sub:IsA("Script") or sub:IsA("LocalScript") then
                    codeOutput = codeOutput .. "   └─ Attached_Script: \"" .. sub.Name .. "\"\n"
                end
            end
        end
    end
    
    if not foundSound then
        codeOutput = codeOutput .. "\n-- [ALERT] No active audio stream found at this frame.\n"
    end
    
    return codeOutput
end

