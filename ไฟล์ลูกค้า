local function CopyIdWithEffect(button, audioId)
    setclipboard(tostring(audioId))
    local originalText = button.Text
    local originalColor = button.BackgroundColor3
    local originalSize = button.Size
    
    button.Text = "COPIED"
    button.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    
    TweenService:Create(button, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + 6, originalSize.Y.Scale, originalSize.Y.Offset + 4)
    }):Play()
    
    task.wait(0.15)
    
    TweenService:Create(button, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = originalSize
    }):Play()
    
    task.delay(1, function()
