-- [ ระบบเซฟและโหลดข้อมูลลงเครื่องอัตโนมัติ ]
local SAVE_FILE_NAME = "RoSky_SaveData.json"

local function SaveDataToDevice()
    local data = {
        Favorites = SavedFavorites,
        Blacklist = BlacklistedAudioIds
    }
    local success, encoded = pcall(function()
        return HttpService:JSONEncode(data)
    end)
    if success then
        pcall(function()
            writefile(SAVE_FILE_NAME, encoded)
        end)
    end
end

local function LoadDataFromDevice()
    if isfile and isfile(SAVE_FILE_NAME) then
        local success, content = pcall(function()
            return readfile(SAVE_FILE_NAME)
        end)
        if success and content then
            local decodedSuccess, decodedData = pcall(function()
                return HttpService:JSONDecode(content)
            end)
            if decodedSuccess and decodedData then
                if decodedData.Favorites then SavedFavorites = decodedData.Favorites end
                if decodedData.Blacklist then BlacklistedAudioIds = decodedData.Blacklist end
            end
        end
    end
end

