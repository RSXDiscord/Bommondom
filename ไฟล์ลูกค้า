-- ฟังก์ชันเฟดและเปลี่ยนหน้าแบบมีอนิเมชั่น
local function SwitchPage(targetPage)
    for _, page in pairs(PageContainer:GetChildren()) do
        if page:IsA("GuiObject") then
            if page == targetPage then
                page.Visible = true
                page.Size = UDim2.new(1, 0, 0.8, 0)
                TweenService:Create(page, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, 0, 1, 0)
                }):Play()
            else
                page.Visible = false
            end
        end
    end
end

