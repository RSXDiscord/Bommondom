-- ฟังก์ชันจัดการ Boombox
local function HandleBoombox(state)
    _G.BoomboxActive = state
    if state then
        -- ดึง Boombox มาถือทันที
        for _, item in pairs(Player.Backpack:GetChildren()) do
            if item.Name == "Boombox" then
                item.Parent = Player.Character
            end
        end
        
        task.spawn(function()
            while _G.BoomboxActive do
                pcall(function()
                    local char = Player.Character
                    local tool = char:FindFirstChild("Boombox")
                    
                    if tool and tool:FindFirstChild("Handle") then
                        tool.Handle.Massless = true
                        tool.Handle.CanCollide = false
                        
                        local rightGrip = char:FindFirstChild("RightGrip", true)
                        if rightGrip then rightGrip.Enabled = false end

                        -- วาร์ปไปไว้ใต้เท้า
                        tool.Handle.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)
                        
                        -- ตัดอนิเมชั่นถือ
                        for _, track in pairs(char.Humanoid:GetPlayingAnimationTracks()) do
                            if track.Name == "ToolHold" or track.Name == "Hold" then
                                track:Stop()
                            end
                        end
                    end
                end)
                task.wait()
            end
        end)
    end
end

