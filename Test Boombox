local function SetupRainbow(object)
    task.spawn(function()
        local hue = 0
        while object and object.Parent do
            hue = hue + 0.005
            if hue > 1 then hue = 0 end
            object.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
            task.wait(0.05)
        end
    end)
end

