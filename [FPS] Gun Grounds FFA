CreateToggle("Silent Aim / Lock", 85, function(state)
    _G.Silent = state
    RunService.RenderStepped:Connect(function()
        if _G.Silent then
            local target = nil
            local dist = math.huge
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (p.Character.HumanoidRootPart.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then target = p.Character.HumanoidRootPart dist = d end
                end
            end
            if target then workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position) end
        end
    end)
end)

CreateToggle("Spin Bot", 125, function(state)
    _G.Spin = state
    Player.CharacterAdded:Connect(function(char)
        if _G.Spin then
            task.spawn(function()
                while _G.Spin do
                    char:WaitForChild("HumanoidRootPart").CFrame = char.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(45), 0)
                    task.wait()
                end
            end)
        end
    end)
    task.spawn(function()
        while _G.Spin do
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                Player.Character.HumanoidRootPart.CFrame = Player.Character.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(45), 0)
            end
            task.wait()
        end
    end)
end)

