CreateToggle("Grip/Metatable Mod", 325, function(state)
    if state then
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        local old = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local args = {...}
            if getnamecallmethod() == "FireServer" and tostring(self) == "Action" then
                args[2] = "hit"
            end
            return old(self, unpack(args))
        end)
    end
end)

