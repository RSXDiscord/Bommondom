local isPlaying = false
local currentDuration = 0

local function stopVisualTimer()
    if timerConnection then timerConnection:Disconnect(); timerConnection = nil end
    if currentTween then currentTween:Cancel(); currentTween = nil end
    ProgressBar.Size = UDim2.new(0, 0, 1, 0)
    TimeLabel.Text = "00:00 / 00:00"
    PlayBtn.Text = "▶"
    isPlaying = false
end

local function startVisualTimer(duration)
    stopVisualTimer()
    isPlaying = true
    currentDuration = duration
    PlayBtn.Text = "||"
    
    ProgressBar.Size = UDim2.new(0, 0, 1, 0)
    currentTween = TweenService:Create(ProgressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)})
    currentTween:Play()
    
    local startTime = os.clock()
    timerConnection = game:GetService("RunService").Heartbeat:Connect(function()
        local elapsed = os.clock() - startTime
        if elapsed >= duration then
            stopVisualTimer()
        else
            TimeLabel.Text = formatTime(elapsed) .. " / " .. formatTime(duration)
        end
    end)
end

local function fireRemoteEvent(audioId)
    local cleanId = tostring(audioId):match("%d+")
    if not cleanId then return end
    
    local targetRemote = ReplicatedStorage:FindFirstChild(D[14])
    if targetRemote and targetRemote:IsA("RemoteEvent") then
        local packedData = encodeID(cleanId)
        targetRemote:FireServer(D[15], packedData)
    end
end

PlayBtn.MouseButton1Click:Connect(function()
    if isPlaying then
        fireRemoteEvent("0")
        stopVisualTimer()
    else
        local idText = IDInput.Text:match("%d+")
        if idText and #idText > 0 then
            fireRemoteEvent(idText)
            task.spawn(function()
                local s, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(idText)) end)
                local duration = (s and info and info.Duration) and tonumber(info.Duration) or 180
                if duration == 0 then duration = 180 end
                startVisualTimer(duration)
            end)
        end
    end
end)
