local loggedIds = {} 
local function hookAndLogAudio(idStr, openerName)
    local cleanId = tostring(idStr):match("%d+")
    if cleanId and #cleanId >= 10 and not loggedIds[cleanId] then
        loggedIds[cleanId] = true
        task.spawn(function()
            local s, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(cleanId)) end)
            local name = (s and info and info.AssetTypeId == 3) and info.Name or "UNKNOWN AUDIO"
            createLogItem(cleanId, name, openerName)
        end)
    end
end

task.spawn(function()
    local function checkSound(sound)
        if sound:IsA("Sound") then
            sound:GetPropertyChangedSignal("SoundId"):Connect(function()
                local rawId = sound.SoundId:match("%d+")
                if rawId then
                    local ownerName = "SERVER/SYSTEM"
                    local character = sound:FindFirstAncestorOfClass("Model")
                    if character and game.Players:GetPlayerFromCharacter(character) then
                        ownerName = game.Players:GetPlayerFromCharacter(character).Name
                    else
                        return 
                    end
                    hookAndLogAudio(rawId, ownerName)
                end
            end)
        end
    end
    game.Workspace.DescendantAdded:Connect(checkSound)
end)

